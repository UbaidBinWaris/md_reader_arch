/* ═══════════════════════════════════════════════════════════════════════════
   NanoMark — Premium Light Theme
   Inspired by OpenAI Light / Apple Design / Clean Modern
   Design System: 4px spacing grid, Inter/system font stack
   ═══════════════════════════════════════════════════════════════════════════ */

/* ── Global ──────────────────────────────────────────────────────────────── */

QMainWindow {
    background-color: #ffffff;
    color: #1a1a1a;
    font-family: "Inter", "Segoe UI", "SF Pro Display", system-ui, sans-serif;
    font-size: 13px;
}

QMenuBar {
    background-color: #ffffff;
    color: #1a1a1a;
    border-bottom: 1px solid #e5e5e5;
    padding: 0px;
    font-size: 13px;
    font-weight: 500;
}

QMenuBar::item {
    padding: 6px 12px;
    border-radius: 6px;
    margin: 2px 2px;
}

QMenuBar::item:selected { background-color: #f0f0f0; }
QMenuBar::item:pressed { background-color: #e5e5e5; }

QMenu {
    background-color: #ffffff;
    color: #1a1a1a;
    border: 1px solid #e5e5e5;
    border-radius: 10px;
    padding: 6px;
    font-size: 13px;
}

QMenu::item {
    padding: 8px 32px 8px 16px;
    border-radius: 6px;
    margin: 1px 0;
}

QMenu::item:selected { background-color: #f0f0f0; color: #000000; }
QMenu::item:disabled { color: #b0b0b0; }
QMenu::separator { height: 1px; background: #e5e5e5; margin: 6px 12px; }

QToolBar {
    background-color: #ffffff;
    border-bottom: 1px solid #e5e5e5;
    padding: 4px 8px;
    spacing: 2px;
}

QToolBar QToolButton {
    background: transparent;
    color: #666666;
    border: 1px solid transparent;
    border-radius: 6px;
    padding: 5px 10px;
    font-size: 12px;
    font-weight: 600;
}

QToolBar QToolButton:hover { background-color: #f0f0f0; color: #1a1a1a; border-color: #e5e5e5; }
QToolBar QToolButton:pressed { background-color: #e5e5e5; }
QToolBar::separator { width: 1px; background: #e5e5e5; margin: 6px 6px; }

QTabWidget::pane { border: none; background-color: #ffffff; }
QTabBar { background-color: #ffffff; border-bottom: 1px solid #e5e5e5; }

QTabBar::tab {
    background-color: transparent;
    color: #999999;
    padding: 10px 20px;
    border: none;
    border-bottom: 2px solid transparent;
    font-size: 13px;
    font-weight: 500;
}

QTabBar::tab:selected { color: #1a1a1a; border-bottom: 2px solid #10a37f; }
QTabBar::tab:hover:!selected { color: #666666; background-color: #fafafa; }

QPlainTextEdit {
    background-color: #ffffff;
    color: #1a1a1a;
    border: none;
    selection-background-color: rgba(16, 163, 127, 0.15);
    selection-color: #000000;
    font-family: "JetBrains Mono", "Fira Code", monospace;
    font-size: 14px;
    padding: 8px;
}

QSplitter::handle { background-color: #e5e5e5; }
QSplitter::handle:horizontal { width: 1px; }
QSplitter::handle:hover { background-color: #10a37f; }

QStatusBar {
    background-color: #ffffff;
    color: #999999;
    border-top: 1px solid #e5e5e5;
    font-size: 12px;
    min-height: 28px;
}

QStatusBar QLabel { color: #999999; padding: 0 16px; font-size: 12px; }

QDockWidget { background-color: #fafafa; color: #1a1a1a; font-size: 12px; }

QDockWidget::title {
    background-color: #fafafa;
    color: #999999;
    padding: 8px 16px;
    border-bottom: 1px solid #e5e5e5;
    font-weight: 600;
    font-size: 11px;
}

QTreeView {
    background-color: #fafafa;
    color: #666666;
    border: none;
    font-size: 13px;
}

QTreeView::item { padding: 4px 12px; border-radius: 6px; margin: 1px 4px; }
QTreeView::item:hover { background-color: #f0f0f0; color: #1a1a1a; }
QTreeView::item:selected { background-color: rgba(16, 163, 127, 0.1); color: #10a37f; }
QTreeView::branch { background-color: #fafafa; }

QScrollBar:vertical {
    background-color: transparent;
    width: 8px;
    border: none;
}

QScrollBar::handle:vertical {
    background-color: #d4d4d4;
    border-radius: 4px;
    min-height: 40px;
    margin: 2px;
}

QScrollBar::handle:vertical:hover { background-color: #b0b0b0; }
QScrollBar::handle:vertical:pressed { background-color: #10a37f; }
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical { height: 0; }

QScrollBar:horizontal {
    background-color: transparent;
    height: 8px;
    border: none;
}

QScrollBar::handle:horizontal {
    background-color: #d4d4d4;
    border-radius: 4px;
    min-width: 40px;
    margin: 2px;
}

QScrollBar::handle:horizontal:hover { background-color: #b0b0b0; }
QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal { width: 0; }

QLineEdit {
    background-color: #fafafa;
    color: #1a1a1a;
    border: 1px solid #e5e5e5;
    border-radius: 8px;
    padding: 8px 12px;
    font-size: 13px;
}

QLineEdit:focus { border-color: #10a37f; background-color: #ffffff; }

QPushButton {
    background-color: #fafafa;
    color: #1a1a1a;
    border: 1px solid #e5e5e5;
    border-radius: 8px;
    padding: 8px 16px;
    font-size: 13px;
    font-weight: 500;
}

QPushButton:hover { background-color: #f0f0f0; border-color: #d4d4d4; }
QPushButton:pressed { background-color: #e5e5e5; }

QPushButton#primary { background-color: #10a37f; color: #ffffff; border: none; font-weight: 600; }
QPushButton#primary:hover { background-color: #1a7f64; }

QToolTip {
    background-color: #ffffff;
    color: #1a1a1a;
    border: 1px solid #e5e5e5;
    border-radius: 6px;
    padding: 6px 10px;
    font-size: 12px;
}

QMessageBox, QInputDialog, QDialog { background-color: #ffffff; color: #1a1a1a; }

QProgressBar { background-color: #f0f0f0; border: none; border-radius: 4px; height: 6px; color: transparent; }
QProgressBar::chunk { background-color: #10a37f; border-radius: 4px; }
